                saveUserData();
                if (selectedLabel !== 'None' && address) saveAddressToStorage(address, selectedLabel);
                let total = 0;
                cart.forEach(item => { total += item.price * item.qty; });
                await addDoc(collection(db, "orders"), {
                    userEmail: currentUser.email,
                    customerName: name,
                    phone: phone,
                    address: address,
                    addressLabel: selectedLabel !== 'None' ? selectedLabel : '',
                    items: cart,
                    totalBill: total,
                    status: "Pending",
                    canCancel: true,
                    orderTime: Date.now(),
                    packedTime: null,
                    packingSeconds: null,
                    paymentConfirmed: false,
                    paymentConfirmedTime: null,
                    paymentConfirmedBy: null,
                });
                alert("✅ Order Placed Successfully!");
                cart = [];
                renderCart();
                document.getElementById("checkoutForm").style.display = "none";
                clearAddress(true);
                selectedLabel = 'None';
                updateLabelButtons();
                loadMyOrders();
                updateOrderButton();
            } catch (err) {
                alert("Error placing order: " + err.message);
            }
        };

        function buildOrderCard(docSnap) {
            const order = docSnap.data();
            const div = document.createElement("div");
            div.className = "card";
            let itemsHtml = "";
            if (order.items) order.items.forEach(item => {
                itemsHtml += `<p>${item.name} x ${item.qty} = $${(item.price * item.qty).toFixed(2)}</p>`;
            });
            let statusHtml = `<div class="status-timeline">
                <div class="status-step ${order.status === 'Pending' ? 'active' : (order.status !== 'Pending' && order.status !== 'Cancelled' ? 'completed' : '')}">📦 Placed</div>
                <div class="status-step ${order.status === 'Packed' ? 'active' : (order.status === 'PickedUp' || order.status === 'Delivered' ? 'completed' : '')}">📋 Packed</div>
                <div class="status-step ${order.status === 'PickedUp' ? 'active' : (order.status === 'Delivered' ? 'completed' : '')}">🚴 Picked</div>
                <div class="status-step ${order.status === 'Delivered' ? 'active completed' : ''}">🏠 Delivered</div>
            </div>`;
            let riderInfo = "";
            if (order.riderName) {
                const masked = order.riderName.replace(/(.{2})[^@]*@(.*)/, '$1***@$2');
                riderInfo = `<p><strong>🚴 Rider:</strong> ${masked}</p>`;
            }
            let deliveryTime = order.deliveryTime ? `<p><strong>✅ Delivered:</strong> ${new Date(order.deliveryTime).toLocaleString()}</p>` : '';
            let labelInfo = order.addressLabel ? `<p><strong>🏷️ Label:</strong> ${order.addressLabel}</p>` : '';
            div.innerHTML = `
                <h2>Order #${docSnap.id.slice(-6)}</h2>
                ${statusHtml}
                <p><strong>Status:</strong> <span class="ok">${order.status}</span></p>
                <p><strong>Total:</strong> $${order.totalBill.toFixed(2)}</p>
                <p><strong>Address:</strong> ${order.address}</p>
                ${labelInfo}
                <p><strong>Phone:</strong> ${order.phone}</p>
                ${riderInfo}${deliveryTime}<hr>${itemsHtml}
            `;
            if (order.status === "Pending" || order.status === "Packed") {
                const cancelBtn = document.createElement("button");
                cancelBtn.textContent = "❌ Cancel Order";
                cancelBtn.className = "cancel";
                cancelBtn.onclick = async () => {
                    if (!confirm("Cancel order?")) return;
                    await updateDoc(doc(db, "orders", docSnap.id), {
                        status: "Cancelled",
                        cancelledTime: Date.now(),
                        cancelledBy: currentUser.email,
                        cancelReason: "Customer"
                    });
                    alert("Cancelled");
                    loadMyOrders();
                };
                div.appendChild(cancelBtn);
            }
            return div;
        }

        async function loadMyOrders() {
            if (!currentUser) return;
            const currentContainer = document.getElementById("currentOrders");
            const historyContainer = document.getElementById("historyOrders");
            try {
                const q = query(collection(db, "orders"), where("userEmail", "==", currentUser.email), limit(50));
                const snapshot = await getDocs(q);
                currentContainer.innerHTML = "";
                historyContainer.innerHTML = "";
                if (snapshot.empty) {
                    currentContainer.innerHTML = `<div class="card">No current orders</div>`;
                    historyContainer.innerHTML = `<div class="card">No order history</div>`;
                    return;
                }
                const current = [],
                    history = [];
                snapshot.forEach(docSnap => {
                    const status = docSnap.data().status || "Pending";
                    if (status === "Pending" || status === "Packed" || status === "PickedUp") current.push(docSnap);
                    else history.push(docSnap);
                });
                current.sort((a, b) => (b.data().orderTime || 0) - (a.data().orderTime || 0));
                history.sort((a, b) => (b.data().orderTime || 0) - (a.data().orderTime || 0));
                if (current.length === 0) currentContainer.innerHTML = `<div class="card">No current orders</div>`;
                else current.forEach(d => currentContainer.appendChild(buildOrderCard(d)));
                if (history.length === 0) historyContainer.innerHTML = `<div class="card">No order history</div>`;
                else history.forEach(d => {
                    const card = buildOrderCard(d);
                    const btn = card.querySelector('button.cancel');
                    if (btn) btn.remove();
                    historyContainer.appendChild(card);
                });
            } catch (e) {
                currentContainer.innerHTML = `<div class="card" style="color:red;">Error loading</div>`;
            }
        }

        function setupTabs() {
            const tabs = document.querySelectorAll('.tab-btn');
            const contents = { currentTab: document.getElementById('currentTab'), historyTab: document.getElementById('historyTab') };
            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    tabs.forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    Object.values(contents).forEach(c => c.classList.remove('active'));
                    const target = tab.dataset.tab;
                    if (contents[target]) contents[target].classList.add('active');
                });
            });
        }

        function setupRealtimeCustomerListener() {
            if (unsubscribeCustomer) unsubscribeCustomer();
            if (!currentUser) return;
            const q = query(collection(db, "orders"), where("userEmail", "==", currentUser.email), limit(50));
            unsubscribeCustomer = onSnapshot(q, () => loadMyOrders(), () => {});
        }

        async function loginGoogle() {
            try {
                const result = await signInWithPopup(auth, provider);
                currentUser = result.user;
            } catch (e) { alert("Login failed"); }
        }
        document.getElementById("loginBtn").onclick = loginGoogle;
        document.getElementById("popupLoginBtn").onclick = loginGoogle;

        document.getElementById("logoutBtn").onclick = async () => {
            await signOut(auth);
            document.getElementById("checkoutForm").style.display = "none";
        };

        onAuthStateChanged(auth, async (user) => {
            if (user) {
                currentUser = user;
                const masked = currentUser.email.replace(/(.{2})[^@]*@(.*)/, '$1***@$2');
                document.getElementById("userInfo").innerHTML = `Logged In: ${masked}`;
                document.getElementById("loginPopup").style.display = "none";
                document.getElementById("customerArea").style.display = "block";
                initPhoneBoxes();
                loadUserData();
                loadMyOrders();
                renderSavedAddresses();
                setupRealtimeCustomerListener();
                clearAddress(true);
                updateOrderButton();
                renderCategories(); // show categories with 4 boxes each
            } else {
                currentUser = null;
                document.getElementById("userInfo").innerHTML = "Not Logged In";
                document.getElementById("loginPopup").style.display = "block";
                document.getElementById("customerArea").style.display = "none";
                if (unsubscribeCustomer) { unsubscribeCustomer();
                    unsubscribeCustomer = null; }
            }
        });

        // ---------- INIT ----------
        setupTabs();
        renderCategories();
        renderCart();
        document.getElementById("customerArea").style.display = "none";
    </script>
</body>
</html>
