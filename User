        function setPhoneNumber(num) {
            const inputs = document.querySelectorAll('.phone-digit');
            const digits = num.replace(/\D/g, '').slice(0, 11);
            inputs.forEach((inp, i) => {
                if (i < 2) return;
                const val = digits[i] || '';
                inp.value = val;
                inp.classList.toggle('filled', !!val);
            });
            updateOrderButton();
        }

        function initPhoneBoxes() {
            const container = document.getElementById('phoneContainer');
            container.innerHTML = '';
            const permValues = ['0', '3'];
            for (let i = 0; i < 2; i++) {
                const input = document.createElement('input');
                input.type = 'text';
                input.className = 'phone-digit permanent filled';
                input.value = permValues[i];
                input.disabled = true;
                input.dataset.index = i;
                container.appendChild(input);
            }
            for (let i = 2; i < 11; i++) {
                const input = document.createElement('input');
                input.type = 'text';
                input.maxLength = 1;
                input.inputMode = 'numeric';
                input.pattern = '[0-9]';
                input.className = 'phone-digit';
                input.dataset.index = i;
                input.autocomplete = 'off';
                container.appendChild(input);
            }
            const allInputs = container.querySelectorAll('.phone-digit');
            const dash = document.createElement('span');
            dash.className = 'phone-dash';
            dash.textContent = '—';
            if (allInputs.length >= 4) {
                allInputs[3].parentNode.insertBefore(dash, allInputs[4]);
            }
            const inputs = container.querySelectorAll('.phone-digit:not(.permanent)');
            inputs.forEach((inp, idx) => {
                const actualIdx = idx + 2;
                inp.addEventListener('input', function(e) {
                    const val = this.value;
                    if (val && !/^[0-9]$/.test(val)) { this.value = ''; return; }
                    this.classList.toggle('filled', !!this.value);
                    if (this.value && actualIdx < 10) {
                        const nextEditable = inputs[idx + 1];
                        if (nextEditable) nextEditable.focus();
                    }
                    updateOrderButton();
                    savePhoneToStorage();
                });
                inp.addEventListener('keydown', function(e) {
                    if (e.key === 'Backspace' && !this.value) {
                        if (actualIdx > 2) {
                            const prevEditable = inputs[idx - 1];
                            if (prevEditable) { prevEditable.focus();
                                prevEditable.value = '';
                                prevEditable.classList.remove('filled');
                                updateOrderButton();
                                savePhoneToStorage();
                                e.preventDefault(); }
                        } else {
                            const permBox = container.querySelectorAll('.phone-digit.permanent')[1];
                            if (permBox) permBox.focus();
                            e.preventDefault();
                        }
                    }
                    if (e.key === 'ArrowLeft') {
                        if (actualIdx > 2) {
                            const prevEditable = inputs[idx - 1];
                            if (prevEditable) { prevEditable.focus();
                                e.preventDefault(); }
                        } else {
                            const permBox = container.querySelectorAll('.phone-digit.permanent')[1];
                            if (permBox) { permBox.focus();
                                e.preventDefault(); }
                        }
                    }
                    if (e.key === 'ArrowRight' && actualIdx < 10) {
                        const nextEditable = inputs[idx + 1];
                        if (nextEditable) { nextEditable.focus();
                            e.preventDefault(); }
                    }
                });
                inp.addEventListener('paste', function(e) {
                    e.preventDefault();
                    const paste = (e.clipboardData || window.clipboardData).getData('text');
                    const digits = paste.replace(/\D/g, '').slice(0, 11);
                    if (!digits) return;
                    const remaining = inputs.length - idx;
                    const toPaste = digits.slice(0, remaining);
                    for (let i = 0; i < toPaste.length; i++) {
                        const targetIdx = idx + i;
                        if (targetIdx < inputs.length) {
                            inputs[targetIdx].value = toPaste[i] || '';
                            inputs[targetIdx].classList.toggle('filled', !!inputs[targetIdx].value);
                        }
                    }
                    const nextIdx = Math.min(idx + toPaste.length, inputs.length - 1);
                    if (nextIdx < inputs.length) inputs[nextIdx].focus();
                    updateOrderButton();
                    savePhoneToStorage();
                });
                inp.addEventListener('focus', function() { this.select(); });
            });
            loadPhoneFromStorage();
        }

