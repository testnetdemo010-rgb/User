<!DOCTYPE html>
<html>
<head>
    <title>🛒 Grocery Shop · City Only</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Roboto, Arial, sans-serif;
            padding: 20px;
            background: #f5f7fa;
        }
        .card {
            background: white;
            border: 1px solid #e0e4e8;
            border-radius: 16px;
            padding: 18px;
            margin-bottom: 16px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
        }
        button {
            padding: 10px 18px;
            border: none;
            background: #2a7de1;
            color: white;
            border-radius: 40px;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.15s;
            letter-spacing: 0.3px;
        }
        button:hover {
            opacity: 0.85;
            transform: scale(0.97);
        }
        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        .cancel {
            background: #d93c3c;
        }
        .checkout {
            background: #0b7e3d;
        }
        input {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #d0d7dd;
            border-radius: 40px;
            font-size: 14px;
            background: #fafcff;
        }
        input:disabled {
            background: #f0f2f5;
            color: #1f2a3a;
            border-color: #c5cdd8;
            cursor: not-allowed;
        }
        #loginPopup {
            position: fixed;
            right: 24px;
            bottom: 24px;
            background: white;
            border: 1px solid #dce2ea;
            border-radius: 24px;
            padding: 24px 28px;
            z-index: 9999;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
            backdrop-filter: blur(2px);
        }
        .status-timeline {
            display: flex;
            gap: 6px;
            margin: 12px 0 8px;
            padding: 6px 4px;
            background: #f2f6fc;
            border-radius: 60px;
            flex-wrap: wrap;
        }
        .status-step {
            flex: 1;
            text-align: center;
            padding: 6px 4px;
            border-radius: 40px;
            background: #e4e9f0;
            color: #4a5568;
            font-size: 12px;
            font-weight: 500;
            min-width: 60px;
        }
        .status-step.active {
            background: #1f8b4c;
            color: white;
        }
        .status-step.completed {
            background: #2a7de1;
            color: white;
        }
        .ok {
            color: #1f8b4c;
            font-weight: 700;
        }
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
            gap: 16px;
        }
        .product-card {
            background: white;
            border: 1px solid #e6ecf3;
            border-radius: 20px;
            padding: 18px 10px;
            text-align: center;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.01);
            cursor: pointer;
            transition: all 0.15s;
        }
        .product-card:hover {
            border-color: #2a7de1;
            background: #f8fbff;
        }
        .total-amount {
            font-size: 26px;
            font-weight: 700;
            color: #0b4f2c;
        }
        .orders-tabs {
            display: flex;
            gap: 4px;
            margin: 18px 0 0;
            border-bottom: 2px solid #dce2ea;
            flex-wrap: wrap;
        }
        .tab-btn {
            padding: 12px 22px;
            background: #f0f4fa;
            border: none;
            border-radius: 30px 30px 0 0;
            cursor: pointer;
            font-weight: 600;
            font-size: 15px;
            color: #2c3e50;
            transition: 0.15s;
            margin-right: 2px;
            margin-top: 0;
        }
        .tab-btn:hover {
            background: #e3eaf3;
        }
        .tab-btn.active {
            background: white;
            color: #1a5fc7;
            border: 1px solid #dce2ea;
            border-bottom: 2px solid white;
            position: relative;
            bottom: -2px;
        }
        .tab-btn .badge {
            background: #dce8f8;
            color: #1a5fc7;
            padding: 2px 12px;
            border-radius: 30px;
            font-size: 11px;
            margin-left: 8px;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        .orders-container {
            background: #fafcff;
            border-radius: 0 0 20px 20px;
            padding: 12px 6px;
            border: 1px solid #dce2ea;
            border-top: none;
        }

        /* ========== CLEAN CHECKOUT FORM ========== */
        #checkoutForm {
            display: none;
            background: white;
            padding: 24px;
            border-radius: 24px;
            margin-top: 20px;
            border: 1px solid #e0e8f0;
            max-width: 650px;
        }

        .form-label {
            font-weight: 600;
            font-size: 14px;
            color: #1f2a3a;
            margin-bottom: 6px;
            display: block;
        }

        .form-row {
            margin-bottom: 16px;
        }
        .form-row input {
            width: 100%;
        }

        .address-label-text {
            font-weight: 600;
            font-size: 14px;
            color: #1f2a3a;
            margin-bottom: 6px;
            display: block;
        }
        .address-input-row {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        /* Two initial buttons */
        .address-choice-buttons {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        .address-choice-buttons button {
            flex: 1;
            min-width: 120px;
            padding: 14px 20px;
        }
        .address-choice-buttons .auto-btn {
            background: #28a745;
        }
        .address-choice-buttons .manual-btn {
            background: #1a5fc7;
        }

        /* Auto address display */
        #autoAddressGroup {
            display: none;
            width: 100%;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }
        #autoAddressGroup input {
            flex: 1;
            min-width: 150px;
            background: #f5f6f8;
            border-color: #d0d7dd;
            cursor: default;
        }
        #autoAddressGroup .addr-actions {
            display: flex;
            gap: 6px;
        }
        #autoAddressGroup .addr-actions button {
            padding: 12px 16px;
            font-size: 13px;
            white-space: nowrap;
        }
        .clear-addr-btn {
            background: #dc3545;
        }
        .change-addr-btn {
            background: #6c757d;
        }

        /* Manual Address Fields */
        #manualAddressFields {
            display: none;
            width: 100%;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
        }
        #manualAddressFields input {
            flex: 1;
            min-width: 100px;
        }
        #manualAddressFields input#manualCity {
            flex: 0.5;
            min-width: 80px;
            background: #e9ecef;
            color: #495057;
        }
        #manualAddressFields input#manualArea {
            flex: 1.5;
            min-width: 120px;
        }
        #manualAddressFields input#manualStreet {
            flex: 1.5;
            min-width: 120px;
        }
        #manualAddressFields .manual-actions {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        #manualAddressFields .manual-actions button {
            padding: 12px 18px;
        }
        .manual-save-btn {
            background: #28a745;
        }
        .manual-cancel-btn {
            background: #6c757d;
        }

        .address-status-line {
            font-size: 12px;
            color: #6c7a8a;
            margin-top: 6px;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        .status-badge {
            display: inline-block;
            padding: 2px 14px;
            border-radius: 40px;
            font-size: 12px;
            font-weight: 500;
            background: #eef4fa;
            color: #2d4b6e;
        }
        .status-badge.saved {
            background: #d4edda;
            color: #155724;
        }
        .status-badge.loading {
            background: #fff3cd;
            color: #856404;
        }
        .status-badge.denied {
            background: #f8d7da;
            color: #721c24;
        }
        .status-badge.countdown {
            background: #fff3cd;
            color: #856404;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0% {
                opacity: 1;
                transform: scale(1);
            }
            50% {
                opacity: 0.7;
                transform: scale(0.97);
            }
            100% {
                opacity: 1;
                transform: scale(1);
            }
        }

        .saved-as-section {
            margin-top: 12px;
            display: none;
        }
        .saved-as-section .saved-as-title {
            font-size: 13px;
            color: #6c7a8a;
            font-weight: 500;
            margin-right: 8px;
        }
        .saved-as-section .label-btns {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
            margin-top: 4px;
        }
        .label-btn {
            padding: 6px 16px;
            border-radius: 40px;
            border: 2px solid #d0d7dd;
            background: white;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.2s;
            color: #2d4b6e;
        }
        .label-btn:hover {
            border-color: #1a5fc7;
            background: #f0f6ff;
        }
        .label-btn.active-home {
            border-color: #28a745;
            background: #28a745;
            color: white;
        }
        .label-btn.active-office {
            border-color: #ff9800;
            background: #ff9800;
            color: white;
        }
        .label-btn.active-none {
            border-color: #1a5fc7;
            background: #1a5fc7;
            color: white;
        }

        .saved-addresses-list {
            margin-top: 10px;
        }
        .saved-addr-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            background: #f8f9fa;
            border-radius: 40px;
            margin-bottom: 6px;
            border: 1px solid #e0e4e8;
        }
        .saved-addr-item .addr-label-tag {
            font-weight: 600;
            font-size: 12px;
            min-width: 44px;
            padding: 2px 10px;
            border-radius: 20px;
            text-align: center;
        }
        .saved-addr-item .addr-label-tag.home {
            background: #d4edda;
            color: #155724;
        }
        .saved-addr-item .addr-label-tag.office {
            background: #fff3cd;
            color: #856404;
        }
        .saved-addr-item .addr-text {
            flex: 1;
            font-size: 13px;
            color: #2d4b6e;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .saved-addr-item .addr-actions {
            display: flex;
            gap: 4px;
        }
        .saved-addr-item .addr-actions button {
            padding: 4px 12px;
            font-size: 11px;
            margin: 0;
        }
        .use-addr-btn {
            background: #28a745;
        }
        .del-addr-btn {
            background: #dc3545;
        }
        .no-saved-msg {
            color: #6c7a8a;
            font-size: 13px;
            padding: 6px 0;
        }

        .order-btn {
            width: 100%;
            margin-top: 16px;
            padding: 14px;
            font-size: 16px;
            background: #b0b8c0;
            color: #6c7a8a;
            cursor: not-allowed;
            transition: all 0.3s ease;
            border-radius: 40px;
            border: none;
            font-weight: 700;
        }
        .order-btn.ready {
            background: #0b7e3d;
            color: white;
            cursor: pointer;
            animation: glow 1.5s ease-in-out infinite;
        }
        .order-btn.ready:hover {
            opacity: 0.85;
            transform: scale(0.98);
        }
        @keyframes glow {
            0% {
                box-shadow: 0 0 0 0 rgba(11, 126, 61, 0.4);
            }
            70% {
                box-shadow: 0 0 12px 8px rgba(11, 126, 61, 0.1);
            }
            100% {
                box-shadow: 0 0 0 0 rgba(11, 126, 61, 0);
            }
        }

        /* ========== PHONE 11-BOX WITH PERMANENT 0 3 AND DASH AFTER 4TH ========== */
        .phone-boxes {
            display: flex;
            gap: 3px;
            flex-wrap: wrap;
            align-items: center;
        }
        .phone-boxes input.phone-digit {
            width: 32px;
            height: 42px;
            text-align: center;
            font-size: 18px;
            font-weight: 600;
            padding: 0;
            border: 2px solid #dce2ea;
            border-radius: 8px;
            background: #f8faff;
            transition: all 0.2s ease;
            flex: 0 0 auto;
            color: #1f2a3a;
        }
        .phone-boxes input.phone-digit:focus {
            border-color: #4a8af4;
            box-shadow: 0 0 0 3px rgba(42, 125, 225, 0.15);
            outline: none;
            background: #fff;
        }
        .phone-boxes input.phone-digit.filled {
            border-color: #7ab7f0;
            background: rgba(42, 125, 225, 0.08);
            color: #1a5fc7;
        }
        .phone-boxes input.phone-digit.filled:focus {
            border-color: #4a8af4;
            background: rgba(42, 125, 225, 0.12);
        }
        .phone-boxes input.phone-digit.permanent {
            background: rgba(42, 125, 225, 0.08);
            color: #1a5fc7;
            border-color: #7ab7f0;
            cursor: default;
            font-weight: 700;
        }
        .phone-boxes input.phone-digit.error {
            border-color: #dc3545;
            background: #fff5f5;
        }
        .phone-boxes .phone-dash {
            display: flex;
            align-items: center;
            font-size: 22px;
            font-weight: 300;
            color: #aab3c0;
            padding: 0 2px;
            margin: 0 2px;
        }

        /* Name edit with icon - inline label */
        .name-edit-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .name-edit-wrapper input {
            flex: 1;
        }
        .name-edit-wrapper .edit-hint {
            font-size: 12px;
            color: #6c7a8a;
            white-space: nowrap;
        }
        .name-edit-wrapper .form-label {
            margin-bottom: 0;
            white-space: nowrap;
        }

        /* Phone inline wrapper */
        .phone-inline-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .phone-inline-wrapper .phone-label {
            font-weight: 600;
            font-size: 14px;
            color: #1f2a3a;
            white-space: nowrap;
        }
        .phone-inline-wrapper .phone-boxes {
            flex: 1;
            min-width: 200px;
        }
        .phone-inline-wrapper .phone-hint {
            font-size: 12px;
            color: #6c7a8a;
            white-space: nowrap;
        }

        /* Category boxes with 4 per row */
        .category-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin: 16px 0;
        }
        .category-box {
            background: white;
            border: 2px solid #e6ecf3;
            border-radius: 24px;
            padding: 24px 8px;
            text-align: center;
            cursor: pointer;
            transition: all 0.15s;
            box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        }
        .category-box:hover {
            border-color: #2a7de1;
            background: #f8fbff;
            transform: translateY(-2px);
        }
        .category-box h3 {
            font-size: 18px;
            color: #1f2a3a;
        }
        .category-box .sub {
            font-size: 13px;
            color: #6c7a8a;
            margin-top: 4px;
        }
        @media (max-width: 650px) {
            .category-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .address-choice-buttons {
                flex-direction: column;
            }
            #autoAddressGroup input {
                min-width: 100%;
            }
            #manualAddressFields input {
                min-width: 100% !important;
                flex: 1 1 100% !important;
            }
            .saved-addr-item {
                flex-wrap: wrap;
            }
            .saved-addr-item .addr-text {
                white-space: normal;
                width: 100%;
            }
            .phone-boxes input.phone-digit {
                width: 26px;
                height: 36px;
                font-size: 15px;
            }
            .phone-boxes {
                gap: 2px;
            }
            .phone-boxes .phone-dash {
                font-size: 17px;
                padding: 0 1px;
                margin: 0 1px;
            }
            .phone-inline-wrapper {
                flex-direction: column;
                align-items: stretch;
                gap: 6px;
            }
            .name-edit-wrapper {
                flex-wrap: wrap;
            }
        }
    </style>
</head>
<body>

    <div id="loginPopup">
        <h3 style="margin-bottom:10px;">🔑 Please Login</h3>
        <button id="popupLoginBtn" style="background:#1a5fc7;">Login With Google</button>
    </div>

    <h1 style="display:flex;align-items:center;gap:8px;">🛒 My Grocery Shop</h1>
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin:6px 0 10px;">
        <button id="loginBtn" style="background:#1a5fc7;">Login With Google</button>
        <button id="logoutBtn" style="background:#d93c3c;">Logout</button>
        <h3 id="userInfo" style="font-weight:400;color:#2d4b6e;margin-left:8px;">Not Logged In</h3>
    </div>
    <hr style="margin:12px 0;">

    <div id="customerArea">
        <!-- ====== CATEGORIES SECTION ====== -->
        <div id="categories"></div>

        <!-- ====== PRODUCTS SECTION (hidden initially) ====== -->
        <div id="productsSection" style="display:none;">
            <button onclick="showCategories()">⬅ Back to Categories</button>
            <h2 id="categoryTitle"></h2>
            <div id="products" class="product-grid"></div>
        </div>

        <hr style="margin:16px 0;">
        <h2>🛒 Cart</h2>
        <div id="cart"></div>
        <h3>Total: <span id="total" class="total-amount">$0</span></h3>
        <button id="checkoutBtn" class="checkout">Proceed Checkout</button>

        <!-- ========== CLEAN CHECKOUT FORM ========== -->
        <div id="checkoutForm">
            <h2 style="margin-bottom:16px;">📝 Customer Details</h2>

            <!-- Name - INLINE -->
            <div class="form-row">
                <div class="name-edit-wrapper">
                    <span class="form-label">Name</span>
                    <input type="text" id="name" placeholder="اپنا نام لکھے">
                    <span class="edit-hint">✏️ editable</span>
                </div>
            </div>

            <!-- Phone - INLINE -->
            <div class="form-row">
                <div class="phone-inline-wrapper">
                    <span class="phone-label">Phone</span>
                    <div class="phone-boxes" id="phoneContainer">
                        <!-- 11 boxes generated by JS -->
                    </div>
                    <span class="phone-hint">🔢 03-xxxxxxx</span>
                </div>
            </div>

            <!-- Address -->
            <div class="form-row">
                <label class="address-label-text">Address</label>
                <div class="address-input-row">
                    <!-- Two initial buttons -->
                    <div class="address-choice-buttons" id="addressChoice">
                        <button class="auto-btn" id="autoAddressBtn">📍 Click to Address</button>
                        <button class="manual-btn" id="manualChoiceBtn">✏️ Manual Address</button>
                    </div>

                    <!-- Auto address display (hidden initially) -->
                    <div id="autoAddressGroup">
                        <input type="text" id="address" placeholder="Address will appear here" disabled>
                        <div class="addr-actions">
                            <button class="clear-addr-btn" id="clearAddressBtn">✖ Clear</button>
                            <button class="change-addr-btn" id="changeAddressBtn">↻ Change</button>
                        </div>
                    </div>

                    <!-- Manual Address Fields (hidden initially) -->
                    <div id="manualAddressFields">
                        <input type="text" id="manualCity" value="Fort Abbas" readonly>
                        <input type="text" id="manualArea" placeholder="ٹاؤن کا نام">
                        <input type="text" id="manualStreet" placeholder="گلی نمبر">
                        <div class="manual-actions">
                            <button class="manual-save-btn" id="manualSaveBtn">✅ Save</button>
                            <button class="manual-cancel-btn" id="manualCancelBtn">✖ Cancel</button>
                        </div>
                    </div>
                </div>
                <div class="address-status-line">
                    <span class="status-badge" id="statusBadge">📍 Not set</span>
                    <span id="statusMessage">Select an address method</span>
                </div>
            </div>

            <!-- Saved As - Labels -->
            <div class="saved-as-section" id="savedAsSection">
                <div class="saved-as-title">Saved As</div>
                <div class="label-btns">
                    <button class="label-btn active-none" data-label="None">None</button>
                    <button class="label-btn" data-label="Home">🏠 Home</button>
                    <button class="label-btn" data-label="Office">🏢 Office</button>
                </div>
            </div>

            <!-- Saved Addresses -->
            <div class="saved-addresses-list" id="savedAddressesList">
                <div class="no-saved-msg" id="noSavedMsg">No saved addresses</div>
            </div>

            <button class="order-btn" id="placeOrderBtn">📦 Order</button>
        </div>

        <hr>

        <h2>📋 My Orders</h2>
        <div class="orders-tabs">
            <button class="tab-btn active" data-tab="currentTab">🟢 Current <span class="badge">Pending / Packed / Picked</span></button>
            <button class="tab-btn" data-tab="historyTab">📜 History <span class="badge">Delivered / Cancelled</span></button>
        </div>
        <div class="orders-container">
            <div id="currentTab" class="tab-content active"><div id="currentOrders"></div></div>
            <div id="historyTab" class="tab-content"><div id="historyOrders"></div></div>
        </div>
    </div>

    <script type="module">
        // ---------- FIREBASE IMPORTS ----------
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
        import {
            getFirestore,
            collection,
            addDoc,
            updateDoc,
            doc,
            query,
            where,
            limit,
            getDocs,
            onSnapshot
        } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";
        import {
            getAuth,
            GoogleAuthProvider,
            signInWithPopup,
            onAuthStateChanged,
            signOut
        } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";

        const firebaseConfig = {
            apiKey: "AIzaSyCXSNe9nwJndCLVwVGZYbP_1sOkq5-K_40",
            authDomain: "myorder1-login.firebaseapp.com",
            projectId: "myorder1-login",
            storageBucket: "myorder1-login.firebasestorage.app",
            messagingSenderId: "908669646736",
            appId: "1:908669646736:web:bcd16ca186160ae308e515"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);
        const provider = new GoogleAuthProvider();

        let currentUser = null;
        let cart = [];
        let unsubscribeCustomer = null;

        // location state
