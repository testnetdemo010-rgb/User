        async function reverseGeocode(lat, lng) {
            try {
                const response = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&addressdetails=1&zoom=18`);
                if (!response.ok) throw new Error('Geocoding failed');
                const data = await response.json();
                if (data && data.display_name) {
                    const addr = data.address || {};
                    let city = addr.city || addr.town || addr.village || addr.hamlet || '';
                    if (!city) city = addr.suburb || addr.neighbourhood || '';
                    if (!city) city = addr.municipality || addr.county || '';
                    if (city) return `${city} (${lat.toFixed(5)}, ${lng.toFixed(5)})`;
                    const parts = data.display_name.split(',');
                    if (parts.length >= 2) return `${parts[1].trim()} (${lat.toFixed(5)}, ${lng.toFixed(5)})`;
                    return `${parts[0]?.trim() || 'Location'} (${lat.toFixed(5)}, ${lng.toFixed(5)})`;
                }
                return `Location (${lat.toFixed(5)}, ${lng.toFixed(5)})`;
            } catch (error) {
                console.error('Reverse geocoding error:', error);
                return `Location (${lat.toFixed(5)}, ${lng.toFixed(5)})`;
            }
        }

        function startAutoAddress() {
            if (isCountdownActive) return;
            if (!currentUser) { alert("Please login first"); return; }
            document.getElementById('addressChoice').style.display = 'none';
            updateStatus('⏳ Getting location...', 'loading', 'Requesting location permission...');
            if (!navigator.geolocation) {
                alert('Geolocation not supported');
                updateStatus('❌ Not supported', 'denied', 'Geolocation is not available');
                document.getElementById('addressChoice').style.display = 'flex';
                return;
            }
            const input = document.getElementById('address');
            input.value = 'Fetching address...';
            input.disabled = true;
            document.getElementById('autoAddressGroup').style.display = 'flex';
            document.getElementById('manualAddressFields').style.display = 'none';
            navigator.geolocation.getCurrentPosition(
                async (pos) => {
                    const { latitude, longitude } = pos.coords;
                    const address = await reverseGeocode(latitude, longitude);
                    setAddress(address);
                    if (selectedLabel !== 'None') saveAddressToStorage(address, selectedLabel);
                    renderSavedAddresses();
                },
                (err) => {
                    console.log('Location error:', err.message);
                    if (err.code === 1) updateStatus('⚠️ Permission denied', 'denied', 'Please allow location and try again');
                    else updateStatus('❌ Error', 'denied', 'Unable to get location. Try Manual Address.');
                    document.getElementById('addressChoice').style.display = 'flex';
                    document.getElementById('autoAddressGroup').style.display = 'none';
                    document.getElementById('address').value = '';
                    updateOrderButton();
                }, { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
            );
        }

